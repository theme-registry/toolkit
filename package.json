{
  "name": "@theme-registry/toolkit",
  "version": "0.1.0",
  "description": "Bundler-agnostic theme registry builder with CLI and watcher",
  "license": "MIT",
  "author": {
    "name": "Petyo Stoyanov",
    "email": "petyosv@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/theme-registry/toolkit.git"
  },
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./cli": {
      "import": "./dist/cli.mjs",
      "require": "./dist/cli.cjs"
    }
  },
  "bin": {
    "theme-registry": "dist/cli.cjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "commander": "^12.1.0",
    "glob": "^11.0.0"
  },
  "devDependencies": {
    "@types/chokidar": "^2.1.7",
    "@types/glob": "^8.1.0",
    "@types/node": "^20.17.6",
    "tsup": "^8.1.0",
    "typescript": "^5.6.3"
  }
}
